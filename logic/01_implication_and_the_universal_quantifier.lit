# 3.1 Implication and the Universal Quantifier

# #check
claim:
    forall x R:
        0 <= x
        =>:
            abs(x) = x
    prove:
        do_nothing

# #check
claim:
    forall x, y, epsilon R:
        0 < epsilon
        epsilon <= 1
        abs(x) < epsilon
        abs(y) < epsilon
        =>:
            abs(x * y) < epsilon
    prove:
        do_nothing

# theorem my_lemma
claim:
    forall x, y, epsilon R:
        0 < epsilon
        epsilon <= 1
        abs(x) < epsilon
        abs(y) < epsilon
        =>:
            abs(x * y) < epsilon
    prove:
        do_nothing

