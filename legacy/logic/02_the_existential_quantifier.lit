# 3.2 The Existential Quantifier

claim:
    exists x R:
        2 < x
        x < 3
    prove:
        x = 5 / 2
        2 < 5 / 2
        5 / 2 < 3

claim:
    exists x R:
        2 < x
        x < 3
    prove:
        2 < 5 / 2
        5 / 2 < 3
        x = 5 / 2

claim:
    exists x R:
        2 < x
        x < 3
    prove:
        2 < 5 / 2
        5 / 2 < 3

claim:
    exists x R:
        2 < x
        x < 3
    prove:
        2 < 5 / 2
        5 / 2 < 3

claim:
    exists x R:
        2 < x
        x < 3
    prove:
        do_nothing

have f fn(R) R

prop FnUb(f fn(R) R, a R):
    forall x R: f(x) <= a

prop FnLb(f fn(R) R, a R):
    forall x R: a <= f(x)

prop FnHasUb(f fn(R) R):
    exists a R: $FnUb(f, a)

prop FnHasLb(f fn(R) R):
    exists a R: $FnLb(f, a)

claim:
    forall f, g fn(R) R, a, b R:
        $FnUb(f, a)
        $FnUb(g, b)
        =>:
            $FnUb(fn(x R: f(x) + g(x)), a + b)
    prove:
        forall x R:
            f(x) + g(x) <= a + b
        add_le_add
        $FnUb(f, a)
        $FnUb(g, b)

claim:
    forall f, g fn(R) R:
        $FnHasUb(f)
        $FnHasUb(g)
        =>:
            $FnHasUb(fn(x R: f(x) + g(x)))
    prove:
        exists a R: $FnUb(f, a)
        exists b R: $FnUb(g, b)
        $FnUb(fn(x R: f(x) + g(x)), a + b)
        fnUb_add

claim:
    forall f, g fn(R) R:
        $FnHasLb(f)
        $FnHasLb(g)
        =>:
            $FnHasLb(fn(x R: f(x) + g(x)))
    prove:
        do_nothing

claim:
    forall c R, f fn(R) R:
        $FnHasUb(f)
        c >= 0
        =>:
            $FnHasUb(fn(x R: c * f(x)))
    prove:
        do_nothing

claim:
    forall f, g fn(R) R:
        $FnHasUb(f)
        $FnHasUb(g)
        =>:
            $FnHasUb(fn(x R: f(x) + g(x)))
    prove:
        exists a R: $FnUb(f, a)
        exists b R: $FnUb(g, b)
        $FnUb(fn(x R: f(x) + g(x)), a + b)

claim:
    forall f, g fn(R) R:
        $FnHasUb(f)
        $FnHasUb(g)
        =>:
            $FnHasUb(fn(x R: f(x) + g(x)))
    prove:
        exists a R: $FnUb(f, a)
        exists b R: $FnUb(g, b)
        $FnUb(fn(x R: f(x) + g(x)), a + b)

