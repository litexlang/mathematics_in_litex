# proving identities in algebraic structures

prop ring_property(s nonempty_set, add Fn(s, s)s, mul Fn(s, s)s, one s, zero s, neg Fn(s)s):
    forall a, b, c s:
        add(add(a, b), c) = add(a, add(b, c))
        mul(mul(a, b), c) = mul(a, mul(b, c))
        mul(a, add(b, c)) = add(mul(a, b), mul(a, c))
        mul(add(a, b), c) = add(mul(a, c), mul(b, c))
    forall a, b s:
        add(a, b) = add(b, a)
    forall a s:
        add(zero, a) = add(a, zero) = a
        add(a, neg(a)) = add(neg(a), a) = zero
        mul(a, one) = mul(one, a) = a

struct ring(s nonempty_set):
    zero s
    one s
    add fn(x, y s) s
    mul fn(x, y s) s
    neg fn(x s) s
    <=>:
        $ring_property(s, self.add, self.mul, self.one, self.zero, self.neg)

prop commring_property(s nonempty_set, r struct ring(s)):
    forall a, b s:
        r.mul(a, b) = r.mul(b, a)

forall s nonempty_set, r struct ring(s):
    $ring_property(s, r.add, r.mul, r.one, r.zero, r.neg)

claim:
    prove:
        forall s nonempty_set, r struct ring(s), a, b, c s:
            $commring_property(s, r)
            =>:
                r.mul(r.mul(c, b), a) = r.mul(b, r.mul(a, c))
                r.mul(r.add(a, b), r.add(a, b)) = r.add(r.add(r.mul(a, a), r.add(r.mul(a, b), r.mul(a, b))), r.mul(b, b))
                r.mul(r.add(a, b), r.add(a, r.neg(b))) = r.add(r.mul(a, a), r.neg(r.mul(b, b)))
    # proof of `r.mul(r.mul(c, b), a) = r.mul(b, r.mul(a, c))`
    $ring_property(s, r.add, r.mul, r.one, r.zero, r.neg)
    r.mul(b, c) = r.mul(c, b)
    r.mul(c, a) = r.mul(a, c)
    r.mul(r.mul(c, b), a) = r.mul(r.mul(b, c), a) = r.mul(b, r.mul(c, a)) = r.mul(b, r.mul(a, c))

    # proof of `r.mul(r.add(a, b), r.add(a, b)) = r.add(r.add(r.mul(a, a), r.add(r.mul(a, b), r.mul(a, b))), r.mul(b, b))`
    r.mul(r.add(a, b), a) = r.add(r.mul(a, a), r.mul(b, a))
    r.mul(r.add(a, b), b) = r.add(r.mul(a, b), r.mul(b, b))
    r.mul(r.add(a, b), r.add(a, b)) = r.add(r.mul(r.add(a, b), a), r.mul(r.add(a, b), b)) = r.add(r.add(r.mul(a, a), r.mul(b, a)), r.add(r.mul(a, b), r.mul(b, b))) = r.add(r.mul(a, a), r.add(r.mul(b, a), r.add(r.mul(a, b), r.mul(b, b)))) #= r.add(r.mul(a, a), r.add(r.add(r.mul(b, a), r.mul(a, b)), r.mul(b, b))) = r.add(r.add(r.mul(a, a), r.add(r.mul(a, b), r.mul(a, b))), r.mul(b, b))


    r.add(r.mul(a, a), r.add(r.mul(b, a), r.add(r.mul(a, b), r.mul(b, b)))) = r.add(r.mul(a, a), r.add(r.add(r.mul(b, a), r.mul(a, b)), r.mul(b, b))) #= r.add(r.add(r.mul(a, a), r.add(r.mul(a, b), r.mul(a, b))), r.mul(b, b))

    #----------TODO---------------

    r.mul(r.add(a, b), r.add(a, r.neg(b))) = r.add(r.mul(a, r.add(a, r.neg(b))), r.mul(b, r.add(a, r.neg(b)))) = r.add(r.add(r.mul(a, a), r.mul(a, r.neg(b))), r.add(r.mul(b, a), r.mul(b, r.neg(b)))) = r.add(r.add(r.mul(a, a), r.mul(a, r.neg(b))), r.add(r.mul(a, b), r.mul(b, r.neg(b)))) = r.add(r.mul(a, a), r.add(r.mul(a, r.neg(b)), r.add(r.mul(a, b), r.mul(b, r.neg(b))))) = r.add(r.mul(a, a), r.add(r.add(r.mul(a, r.neg(b)), r.mul(a, b)), r.mul(b, r.neg(b)))) = r.add(r.mul(a, a), r.add(r.mul(a, r.add(b, r.neg(b))), r.mul(b, r.neg(b))))

    r.mul(a, r.zero) = r.mul(a, r.add(r.zero, r.zero)) = r.add(r.mul(a, r.zero), r.mul(a, r.zero))
    r.zero = r.add(r.neg(r.mul(a, r.zero)), r.mul(a, r.zero)) = r.add(r.neg(r.mul(a, r.zero)), r.add(r.mul(a, r.zero), r.mul(a, r.zero))) = r.add(r.add(r.neg(r.mul(a, r.zero)), r.mul(a, r.zero)), r.mul(a, r.zero)) = r.add(r.zero, r.mul(a, r.zero)) = r.mul(a, r.zero)

    r.mul(b, r.neg(b)) = r.add(r.mul(b, r.neg(b)), r.zero) = r.add(r.mul(b, r.neg(b)), r.add(r.mul(b, b), r.neg(r.mul(b, b)))) = r.add(r.add(r.mul(b, r.neg(b)), r.mul(b, b)), r.neg(r.mul(b, b))) = r.add(r.mul(b, r.add(r.neg(b), b)), r.neg(r.mul(b, b))) = r.add(r.mul(b, r.zero), r.neg(r.mul(b, b))) = r.add(r.zero, r.neg(r.mul(b, b))) = r.neg(r.mul(b, b))

    r.mul(r.add(a, b), r.add(a, r.neg(b))) = r.add(r.mul(a, a), r.add(r.mul(a, r.zero), r.mul(b, r.neg(b)))) = r.add(r.mul(a, a), r.add(r.zero, r.mul(b, r.neg(b)))) = r.add(r.mul(a, a), r.mul(b, r.neg(b))) = r.add(r.mul(a, a), r.neg(r.mul(b, b)))
