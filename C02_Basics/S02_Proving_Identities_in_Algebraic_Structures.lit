claim:
    prove:
        forall r nonempty_set, g struct ring(r), a, b, c, d r:
            $commring_property(r, g)
            c = r.add(r.mul(d, a), b)
            b = r.mul(a, d)
            =>:
                c = r.add(r.mul(a, d), r.mul(a, d))
    $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
    c = r.add(r.mul(d, a), b) = r.add(r.mul(d, a), r.mul(a, d)) = r.add(r.mul(a, d), r.mul(a, d))

claim:
    prove:
        forall r nonempty_set, g struct ring(r), a, b r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            =>:
                r.add(r.neg(a), r.add(a, b)) = b # theorem neg_add_cancel_left
                r.add(r.add(a, b), r.neg(b)) = a # theorem add_neg_cancel_right
    r.add(r.neg(a), r.add(a, b)) = r.add(r.add(r.neg(a), a), b) = r.add(r.zero, b) = b
    r.add(r.add(a, b), r.neg(b)) = r.add(a, r.add(b, r.neg(b))) = r.add(a, r.zero) = a

# theorem add_left_cancel
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a, b, c r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            r.add(a, b) = r.add(a, c)
            =>:
                b = c
    r.add(r.neg(a), r.add(a, b)) = r.add(r.neg(a), r.add(a, c))
    r.add(r.neg(a), r.add(a, b)) = r.add(r.add(r.neg(a), a), b) = r.add(r.zero, b) = b
    r.add(r.neg(a), r.add(a, c)) = r.add(r.add(r.neg(a), a), c) = r.add(r.zero, c) = c
    b = c

# theorem add_right_cancel
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a, b, c r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            r.add(a, b) = r.add(c, b)
            =>:
                a = c
    r.add(r.add(a, b), r.neg(b)) = r.add(r.add(c, b), r.neg(b))
    r.add(r.add(a, b), r.neg(b)) = r.add(a, r.add(b, r.neg(b))) = r.add(a, r.zero) = a
    r.add(r.add(c, b), r.neg(b)) = r.add(c, r.add(b, r.neg(b))) = r.add(c, r.zero) = c
    a = c

# theorem mul_zero
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            =>:
                r.mul(a, r.zero) = r.zero
    r.add(r.mul(a, r.zero), r.mul(a, r.zero)) = r.mul(a, r.add(r.zero, r.zero)) = r.mul(a, r.zero) = r.add(r.mul(a, r.zero), r.zero)
    r.add(r.neg(r.mul(a, r.zero)), r.add(r.mul(a, r.zero), r.mul(a, r.zero))) = r.add(r.neg(r.mul(a, r.zero)), r.add(r.mul(a, r.zero), r.zero))
    r.add(r.neg(r.mul(a, r.zero)), r.add(r.mul(a, r.zero), r.mul(a, r.zero))) = r.add(r.add(r.neg(r.mul(a, r.zero)), r.mul(a, r.zero)), r.mul(a, r.zero)) = r.add(r.zero, r.mul(a, r.zero)) = r.mul(a, r.zero)
    r.add(r.neg(r.mul(a, r.zero)), r.add(r.mul(a, r.zero), r.zero)) = r.add(r.add(r.neg(r.mul(a, r.zero)), r.mul(a, r.zero)), r.zero) = r.add(r.zero, r.zero) = r.zero
    r.mul(a, r.zero) = r.zero

# theorem zero_mul
# remember that multiplication is not assumed to be commutative
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            =>:
                r.mul(r.zero, a) = r.zero
    r.add(r.mul(r.zero, a), r.mul(r.zero, a)) = r.mul(r.add(r.zero, r.zero), a) = r.mul(r.zero, a) = r.add(r.mul(r.zero, a), r.zero)
    r.add(r.neg(r.mul(r.zero, a)), r.add(r.mul(r.zero, a), r.mul(r.zero, a))) = r.add(r.neg(r.mul(r.zero, a)), r.add(r.mul(r.zero, a), r.zero))
    r.add(r.neg(r.mul(r.zero, a)), r.add(r.mul(r.zero, a), r.mul(r.zero, a))) = r.add(r.add(r.neg(r.mul(r.zero, a)), r.mul(r.zero, a)), r.mul(r.zero, a)) = r.add(r.zero, r.mul(r.zero, a)) = r.mul(r.zero, a)
    r.add(r.neg(r.mul(r.zero, a)), r.add(r.mul(r.zero, a), r.zero)) = r.add(r.add(r.neg(r.mul(r.zero, a)), r.mul(r.zero, a)), r.zero) = r.add(r.zero, r.zero) = r.zero
    r.mul(r.zero, a) = r.zero

# theorem neg_eq_of_add_eq_zero
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a, b r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            r.add(a, b) = r.zero
            =>:
                r.neg(a) = b
    r.add(a, b) = r.zero = r.add(a, r.neg(a))
    r.add(r.neg(a), r.add(a, b)) = r.add(r.neg(a), r.add(a, r.neg(a)))
    r.add(r.neg(a), r.add(a, b)) = r.add(r.add(r.neg(a), a), b) = r.add(r.zero, b) = b
    r.add(r.neg(a), r.add(a, r.neg(a))) = r.add(r.neg(a), r.zero) = r.neg(a)
    r.neg(a) = b

# theorem eq_neg_of_add_eq_zero
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a, b r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            r.add(a, b) = r.zero
            =>:
                a = r.neg(b)
    r.add(r.add(a, b), r.neg(b)) = r.add(r.zero, r.neg(b)) = r.neg(b)
    r.add(r.add(a, b), r.neg(b)) = r.add(a, r.add(b, r.neg(b))) = r.add(a, r.zero) = a
    a = r.neg(b)

# theorem neg_zero
claim:
    prove:
        forall r nonempty_set, g struct ring(r):
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            =>:
                r.neg(r.zero) = r.zero
    r.add(r.zero, r.zero) = r.zero
    r.add(r.neg(r.zero), r.add(r.zero, r.zero)) = r.add(r.neg(r.zero), r.zero)
    r.add(r.neg(r.zero), r.add(r.zero, r.zero)) = r.add(r.add(r.neg(r.zero), r.zero), r.zero) = r.add(r.zero, r.zero) = r.zero
    r.add(r.neg(r.zero), r.zero) = r.neg(r.zero)
    r.neg(r.zero) = r.zero

# theorem neg_neg
claim:
    prove:
        forall r nonempty_set, g struct ring(r), a r:
            $ring_property(r, r.add, r.mul, r.one, r.zero, r.neg)
            =>:
                r.neg(r.neg(a)) = a
    r.add(r.neg(r.neg(a)), r.neg(a)) = r.zero
    r.add(r.add(r.neg(r.neg(a)), r.neg(a)), a) = r.add(r.zero, a) = a
    r.add(r.add(r.neg(r.neg(a)), r.neg(a)), a) = r.add(r.neg(r.neg(a)), r.add(r.neg(a), a)) = r.add(r.neg(r.neg(a)), r.zero) = r.neg(r.neg(a))
    r.neg(r.neg(a)) = a

